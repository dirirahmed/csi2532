<!DOCTYPE html>
<html lang="fr">
<head>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { background:#121416; color:white; }
        .card { background:#212529; border:1px solid #495057; }
        .form-control, .form-select { background-color: #2b3035 !important; color: white !important; border: 1px solid #495057; }
    </style>
    <title>Administration</title>
</head>
<body class="container py-5">
    <div class="d-flex justify-content-between mb-5">
        <h2 style="color: #ffc107;">⚙️ Administration (CRUD)</h2>
        <div>
            <a href="/stats" class="btn btn-info btn-sm">Stats</a>
            <a href="/" class="btn btn-outline-light btn-sm ms-2">Accueil</a>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-md-6">
            <div class="card p-4">
                <h5>Gestion Personnes</h5>
                <form class="mt-3">
                    <input type="text" class="form-control mb-2" placeholder="Nom">
                    <input type="text" class="form-control mb-2" placeholder="NAS">
                    <select class="form-select mb-3">
                        <option>Client</option>
                        <option>Employé</option>
                        <option>Gestionnaire</option>
                    </select>
                    <button class="btn btn-warning w-100 fw-bold">Enregistrer</button>
                </form>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card p-4">
                <h5>Gestion Logements</h5>
                <form class="mt-3">
                    <input type="text" class="form-control mb-2" placeholder="Hôtel">
                    <input type="number" class="form-control mb-2" placeholder="Prix">
                    <select class="form-select mb-3">
                        <option>Simple</option>
                        <option>Double</option>
                        <option>Suite</option>
                    </select>
                    <button class="btn btn-warning w-100 fw-bold">Enregistrer</button>
                </form>
            </div>
        </div>
    </div>
</body>
</html>