<!DOCTYPE html>
<html lang="fr">

<head>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body {
            background: #121416;
            color: white;
        }
        
        .card {
            background: #212529;
            border: 1px solid #495057;
        }
        
        .form-control,
        .form-select {
            background-color: #2b3035 !important;
            color: white !important;
            border: 1px solid #495057;
        }
    </style>
    <title>Administration</title>
</head>

<body class="container py-5">
    <div class="d-flex justify-content-between mb-5">
        <h2 style="color: #ffc107;">⚙️ Administration (CRUD)</h2>
        <div>
            <a href="/stats" class="btn btn-info btn-sm">Stats</a>
            <a href="/" class="btn btn-outline-light btn-sm ms-2">Accueil</a>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-md-6">
            <div class="card p-4">
                <h5>Ajouter un Client</h5>
                <form action="/admin/add-client" method="POST" class="mt-3">
                    <input type="text" name="nom" class="form-control mb-2" placeholder="Nom Complet" required>
                    <input type="text" name="adresse" class="form-control mb-2" placeholder="Adresse" required>
                    <input type="text" name="nas" class="form-control mb-2" placeholder="NAS" required>
                    <button type="submit" class="btn btn-warning w-100 fw-bold">Enregistrer Client</button>
                </form>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card p-4">
                <h5>Ajouter une Chambre</h5>
                <form action="/admin/add-room" method="POST" class="mt-3">
                    <input type="number" name="hotel_id" class="form-control mb-2" placeholder="ID de l'Hôtel" required>
                    <input type="number" name="prix" class="form-control mb-2" placeholder="Prix" required>
                    <select name="capacite" class="form-select mb-3">
                        <option value="simple">Simple</option>
                        <option value="double">Double</option>
                        <option value="suite">Suite</option>
                    </select>
                    <button type="submit" class="btn btn-warning w-100 fw-bold">Enregistrer Chambre</button>
                </form>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card p-4">
                <h5>Ajouter un Employé</h5>
                <form action="/admin/add-employee" method="POST" class="mt-3">
                    <input type="text" name="nom" class="form-control mb-2" placeholder="Nom Complet" required>
                    <input type="text" name="nas" class="form-control mb-2" placeholder="NAS" required>
                    <input type="text" name="role" class="form-control mb-2" placeholder="Rôle (ex: Gestionnaire)" required>
                    <input type="number" name="hotel_id" class="form-control mb-2" placeholder="ID Hôtel" required>
                    <button type="submit" class="btn btn-warning w-100 fw-bold">Enregistrer Employé</button>
                </form>
            </div>
        </div>
    </div>
</body>

</html>