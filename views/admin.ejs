<!DOCTYPE html>
<html class="dark" lang="fr">
<head>
  <meta charset="utf-8"/>
  <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
  <title>e-Hotels Database - Admin</title>
  <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet"/>
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
  <link href="/styles/ui.css" rel="stylesheet"/>
  <script>
    tailwind.config = {
      darkMode: 'class',
      theme: {
        extend: {
          colors: {
            background: '#0e0e0e',
            surface: '#0e0e0e',
            'surface-container-low': '#121413',
            'surface-container': '#181a19',
            'surface-container-highest': '#242625',
            primary: '#3cddc7',
            'primary-container': '#005047',
            'on-primary': '#004941',
            'on-surface': '#e5e6e4',
            'on-surface-variant': '#aaabaa'
          }
        }
      }
    };
  </script>
</head>
<body class="bg-background text-on-surface min-h-screen flex">
  <%
    const showEmployeeReturn = typeof returnToEmployee !== 'undefined' ? returnToEmployee : false;
    const clientRows = typeof clients !== 'undefined' ? clients : [];
    const employeeRows = typeof employees !== 'undefined' ? employees : [];
    const roomRows = typeof rooms !== 'undefined' ? rooms : [];
    const scopedAdminSession = typeof adminSession !== 'undefined' ? adminSession : null;
  %>
  <aside class="hidden md:flex sticky top-0 flex-col h-screen py-6 px-4 gap-8 bg-[#0e0e0e] border-r border-white/5 w-64 shrink-0 self-start">
    <div class="flex items-center gap-3 px-2">
      <div class="w-8 h-8 rounded-lg signature-gradient flex items-center justify-center">
        <span class="material-symbols-outlined text-on-primary text-sm">inventory_2</span>
      </div>
      <div class="flex flex-col">
        <span class="text-teal-400 font-black tracking-tight leading-none">e-Hotels</span>
        <span class="text-[10px] text-on-surface-variant font-medium">CSI2532 Project</span>
      </div>
    </div>
    <nav class="flex flex-col gap-2 flex-grow">
      <a class="flex items-center gap-3 text-[#aaabaa] px-4 py-2 hover:bg-[#181a19] rounded-lg transition-all font-medium text-sm" href="/">
        <span class="material-symbols-outlined text-lg">dashboard</span>
        <span>Accueil</span>
      </a>
      <a class="flex items-center gap-3 text-[#aaabaa] px-4 py-2 hover:bg-[#181a19] rounded-lg transition-all font-medium text-sm" href="/employe">
        <span class="material-symbols-outlined text-lg">badge</span>
        <span>Employe</span>
      </a>
    </nav>
  </aside>

  <main class="flex-grow flex flex-col min-w-0 overflow-y-auto pb-8">
    <header class="bg-[#121413]/80 backdrop-blur-lg flex items-center justify-between w-full px-8 h-16 sticky top-0 z-50 border-b border-white/5">
      <div class="flex items-center gap-5">
        <% if (showEmployeeReturn) { %>
          <a class="flex items-center gap-2 text-on-surface-variant hover:text-on-surface transition-colors" href="/employe">
            <span class="material-symbols-outlined text-base">arrow_back</span>
            <span class="text-sm font-medium">Retour</span>
          </a>
          <div class="h-6 w-px bg-white/10"></div>
        <% } %>
        <div class="flex flex-col">
          <span class="text-teal-400 font-bold tracking-tighter uppercase text-sm">e-Hotels</span>
          <span class="text-[10px] text-on-surface-variant uppercase tracking-widest font-bold">Admin Console</span>
        </div>
      </div>
      <a class="flex items-center gap-2 px-4 py-2 bg-surface-container-highest border border-white/10 text-primary rounded-lg text-xs font-bold uppercase tracking-widest hover:border-primary/50 hover:bg-surface-container transition-all" href="/stats">
        <span class="material-symbols-outlined text-sm">analytics</span>
        <span>Stats</span>
      </a>
    </header>

    <section class="p-6 lg:p-8 max-w-6xl mx-auto w-full">
      <div class="mb-8">
        <h2 class="text-2xl lg:text-3xl font-extrabold tracking-tight text-on-surface mb-2">Administration</h2>
        <p class="text-on-surface-variant max-w-2xl">
          <% if (scopedAdminSession) { %>
            Gestion limitee a <%= scopedAdminSession.hotel_name %>.
          <% } else { %>
            Ajouter des clients, des chambres et des employes pour la demonstration.
          <% } %>
        </p>
      </div>

      <div class="grid grid-cols-1 xl:grid-cols-2 gap-6">
        <div class="bg-surface-container-low rounded-xl p-5 lg:p-6 ghost-border">
          <div class="flex items-center gap-3 mb-5">
            <span class="material-symbols-outlined text-primary p-2 bg-primary/10 rounded-lg">person_add</span>
            <h3 class="text-lg font-bold tracking-tight text-on-surface">Ajouter un client</h3>
          </div>
          <form action="/admin/add-client" method="POST" class="space-y-5">
            <% if (scopedAdminSession) { %>
              <input type="hidden" name="admin_employee_id" value="<%= scopedAdminSession.employee_id %>"/>
              <input type="hidden" name="admin_hotel_id" value="<%= scopedAdminSession.hotel_id %>"/>
            <% } %>
            <div>
              <label class="block text-[11px] font-bold uppercase tracking-wider text-on-surface-variant mb-1.5 ml-1">Nom complet</label>
              <input class="w-full bg-surface-container-highest border-none rounded-lg p-3 text-on-surface focus:ring-1 focus:ring-primary placeholder:text-on-surface-variant/50" name="nom" placeholder="Nom complet" required type="text"/>
            </div>
            <div>
              <label class="block text-[11px] font-bold uppercase tracking-wider text-on-surface-variant mb-1.5 ml-1">Adresse</label>
              <input class="w-full bg-surface-container-highest border-none rounded-lg p-3 text-on-surface focus:ring-1 focus:ring-primary placeholder:text-on-surface-variant/50" name="adresse" placeholder="Adresse" required type="text"/>
            </div>
            <div>
              <label class="block text-[11px] font-bold uppercase tracking-wider text-on-surface-variant mb-1.5 ml-1">NAS</label>
              <input class="w-full bg-surface-container-highest border-none rounded-lg p-3 text-on-surface focus:ring-1 focus:ring-primary placeholder:text-on-surface-variant/50" inputmode="numeric" maxlength="9" minlength="9" name="nas" pattern="[0-9]{9}" placeholder="000000000" required type="text"/>
            </div>
            <button class="w-full signature-gradient text-on-primary font-bold py-3 px-6 rounded-lg hover:opacity-90 transition-all active:scale-[0.98]" type="submit">Enregistrer client</button>
          </form>
        </div>

        <div class="bg-surface-container rounded-xl p-5 lg:p-6 border border-white/5">
          <div class="flex items-center gap-3 mb-5">
            <span class="material-symbols-outlined text-primary p-2 bg-primary/10 rounded-lg">meeting_room</span>
            <h3 class="text-lg font-bold tracking-tight text-on-surface">Ajouter une chambre</h3>
          </div>
          <form action="/admin/add-room" method="POST" class="space-y-5">
            <% if (scopedAdminSession) { %>
              <input type="hidden" name="admin_employee_id" value="<%= scopedAdminSession.employee_id %>"/>
              <input type="hidden" name="admin_hotel_id" value="<%= scopedAdminSession.hotel_id %>"/>
            <% } %>
            <div>
              <label class="block text-[11px] font-bold uppercase tracking-wider text-on-surface-variant mb-1.5 ml-1">Hotel</label>
              <select class="w-full bg-surface-container-highest border-none rounded-lg p-3 text-on-surface focus:ring-1 focus:ring-primary" name="hotel_id" required>
                <option value="">Choisir un hotel</option>
                <% hotels.forEach(hotel => { %>
                  <option value="<%= hotel.hotel_id %>">#<%= hotel.hotel_id %> - <%= hotel.name %></option>
                <% }) %>
              </select>
            </div>
            <div>
              <label class="block text-[11px] font-bold uppercase tracking-wider text-on-surface-variant mb-1.5 ml-1">Numero de chambre</label>
              <input class="w-full bg-surface-container-highest border-none rounded-lg p-3 text-on-surface focus:ring-1 focus:ring-primary" name="room_number" required type="text"/>
            </div>
            <div>
              <label class="block text-[11px] font-bold uppercase tracking-wider text-on-surface-variant mb-1.5 ml-1">Prix</label>
              <input class="w-full bg-surface-container-highest border-none rounded-lg p-3 text-on-surface focus:ring-1 focus:ring-primary" min="0" name="prix" required step="0.01" type="number"/>
            </div>
            <div>
              <label class="block text-[11px] font-bold uppercase tracking-wider text-on-surface-variant mb-1.5 ml-1">Capacite</label>
              <select class="w-full bg-surface-container-highest border-none rounded-lg p-3 text-on-surface focus:ring-1 focus:ring-primary" name="capacite">
                <option value="Single">Simple</option>
                <option value="Double">Double</option>
                <option value="Suite">Suite</option>
                <option value="Family">Family</option>
              </select>
            </div>
            <div>
              <label class="block text-[11px] font-bold uppercase tracking-wider text-on-surface-variant mb-1.5 ml-1">Vue</label>
              <select class="w-full bg-surface-container-highest border-none rounded-lg p-3 text-on-surface focus:ring-1 focus:ring-primary" name="vue">
                <option value="Sea">Sea</option>
                <option value="Mountain">Mountain</option>
                <option value="City">City</option>
                <option value="Garden">Garden</option>
                <option value="None">None</option>
              </select>
            </div>
            <div>
              <label class="block text-[11px] font-bold uppercase tracking-wider text-on-surface-variant mb-1.5 ml-1">Superficie</label>
              <input class="w-full bg-surface-container-highest border-none rounded-lg p-3 text-on-surface focus:ring-1 focus:ring-primary" min="0" name="area" required step="0.01" type="number"/>
            </div>
            <div>
              <label class="block text-[11px] font-bold uppercase tracking-wider text-on-surface-variant mb-1.5 ml-1">Lit additionnel</label>
              <select class="w-full bg-surface-container-highest border-none rounded-lg p-3 text-on-surface focus:ring-1 focus:ring-primary" name="extendable_bed">
                <option value="0">Non</option>
                <option value="1">Oui</option>
              </select>
            </div>
            <div class="md:col-span-2">
              <label class="block text-[11px] font-bold uppercase tracking-wider text-on-surface-variant mb-1.5 ml-1">Commodites</label>
              <input class="w-full bg-surface-container-highest border-none rounded-lg p-3 text-on-surface focus:ring-1 focus:ring-primary" name="commodites" placeholder="TV, AC, WiFi" type="text"/>
            </div>
            <div class="md:col-span-2">
              <label class="block text-[11px] font-bold uppercase tracking-wider text-on-surface-variant mb-1.5 ml-1">Etat / dommages</label>
              <input class="w-full bg-surface-container-highest border-none rounded-lg p-3 text-on-surface focus:ring-1 focus:ring-primary" name="damage_status" placeholder="None" type="text"/>
            </div>
            <button class="w-full signature-gradient text-on-primary font-bold py-3 px-6 rounded-lg hover:opacity-90 transition-all active:scale-[0.98]" type="submit">Enregistrer chambre</button>
          </form>
        </div>

        <% if (!scopedAdminSession) { %>
        <div class="bg-surface-container rounded-xl p-5 lg:p-6 border border-white/5">
          <div class="flex items-center gap-3 mb-5">
            <span class="material-symbols-outlined text-primary p-2 bg-primary/10 rounded-lg">apartment</span>
            <h3 class="text-lg font-bold tracking-tight text-on-surface">Ajouter un hotel</h3>
          </div>
          <form action="/admin/add-hotel" method="POST" class="space-y-4">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <select class="w-full bg-surface-container-highest border-none rounded-lg p-3 text-on-surface focus:ring-1 focus:ring-primary" name="chain_id" required>
                <option value="">Choisir une chaine</option>
                <% chains.forEach(chain => { %>
                  <option value="<%= chain.id %>"><%= chain.name %></option>
                <% }) %>
              </select>
              <input class="w-full bg-surface-container-highest border-none rounded-lg p-3 text-on-surface focus:ring-1 focus:ring-primary" max="5" min="1" name="categorie" placeholder="Categorie" required type="number"/>
            </div>
            <input class="w-full bg-surface-container-highest border-none rounded-lg p-3 text-on-surface focus:ring-1 focus:ring-primary" name="nom" placeholder="Nom de l'hotel" required type="text"/>
            <input class="w-full bg-surface-container-highest border-none rounded-lg p-3 text-on-surface focus:ring-1 focus:ring-primary" name="adresse" placeholder="Adresse" required type="text"/>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <select class="w-full bg-surface-container-highest border-none rounded-lg p-3 text-on-surface focus:ring-1 focus:ring-primary" name="ville" required>
                <option value="">Choisir une ville</option>
                <% cities.forEach(city => { %>
                  <option value="<%= city %>"><%= city %></option>
                <% }) %>
              </select>
              <input class="w-full bg-surface-container-highest border-none rounded-lg p-3 text-on-surface focus:ring-1 focus:ring-primary" name="province_state" placeholder="Province / Etat" required type="text"/>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <input class="w-full bg-surface-container-highest border-none rounded-lg p-3 text-on-surface focus:ring-1 focus:ring-primary" name="country" placeholder="Pays" required type="text"/>
              <input class="w-full bg-surface-container-highest border-none rounded-lg p-3 text-on-surface focus:ring-1 focus:ring-primary" name="postal_code" placeholder="Code postal" required type="text"/>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <input class="w-full bg-surface-container-highest border-none rounded-lg p-3 text-on-surface focus:ring-1 focus:ring-primary" name="email" placeholder="Email" required type="email"/>
              <input class="w-full bg-surface-container-highest border-none rounded-lg p-3 text-on-surface focus:ring-1 focus:ring-primary" name="phone" placeholder="Telephone" required type="text"/>
            </div>
            <button class="w-full signature-gradient text-on-primary font-bold py-3 px-6 rounded-lg hover:opacity-90 transition-all active:scale-[0.98]" type="submit">Enregistrer hotel</button>
          </form>
        </div>
        <% } %>

        <div class="xl:col-span-2 bg-surface-container-low rounded-xl p-6 lg:p-7 ghost-border">
          <div class="flex items-center gap-4 mb-6">
            <div class="w-12 h-12 rounded-full bg-primary/10 flex items-center justify-center">
              <span class="material-symbols-outlined text-primary text-3xl">engineering</span>
            </div>
            <div>
              <h3 class="text-xl font-bold tracking-tight text-on-surface">Ajouter un employe</h3>
              <p class="text-xs text-on-surface-variant uppercase tracking-tighter">Gestion simple des employes</p>
            </div>
          </div>

          <form action="/admin/add-employee" method="POST" class="grid grid-cols-1 md:grid-cols-2 gap-5">
            <% if (scopedAdminSession) { %>
              <input type="hidden" name="admin_employee_id" value="<%= scopedAdminSession.employee_id %>"/>
              <input type="hidden" name="admin_hotel_id" value="<%= scopedAdminSession.hotel_id %>"/>
            <% } %>
            <div>
              <label class="block text-[11px] font-bold uppercase tracking-wider text-on-surface-variant mb-1.5 ml-1">Nom complet</label>
              <input class="w-full bg-surface-container-highest border-none rounded-lg p-3 text-on-surface focus:ring-1 focus:ring-primary" name="nom" required type="text"/>
            </div>
            <div>
              <label class="block text-[11px] font-bold uppercase tracking-wider text-on-surface-variant mb-1.5 ml-1">NAS</label>
              <input class="w-full bg-surface-container-highest border-none rounded-lg p-3 text-on-surface focus:ring-1 focus:ring-primary" inputmode="numeric" maxlength="9" minlength="9" name="nas" pattern="[0-9]{9}" required type="text"/>
            </div>
            <div>
              <label class="block text-[11px] font-bold uppercase tracking-wider text-on-surface-variant mb-1.5 ml-1">Role</label>
              <select class="w-full bg-surface-container-highest border-none rounded-lg p-3 text-on-surface focus:ring-1 focus:ring-primary" name="role">
                <option value="Manager">Manager</option>
                <option value="Receptionist">Receptionist</option>
                <option value="Housekeeping">Housekeeping</option>
                <option value="Admin">Admin</option>
                <option value="Other">Other</option>
              </select>
            </div>
            <div>
              <label class="block text-[11px] font-bold uppercase tracking-wider text-on-surface-variant mb-1.5 ml-1">Hotel</label>
              <select class="w-full bg-surface-container-highest border-none rounded-lg p-3 text-on-surface focus:ring-1 focus:ring-primary" name="hotel_id" required>
                <option value="">Choisir un hotel</option>
                <% hotels.forEach(hotel => { %>
                  <option value="<%= hotel.hotel_id %>">#<%= hotel.hotel_id %> - <%= hotel.name %></option>
                <% }) %>
              </select>
            </div>
            <div class="md:col-span-2">
              <button class="w-full signature-gradient text-on-primary font-bold py-3.5 px-6 rounded-lg hover:opacity-90 transition-all active:scale-[0.98]" type="submit">Enregistrer employe</button>
            </div>
          </form>
        </div>
      </div>

      <div class="mt-8 grid grid-cols-1 xl:grid-cols-2 gap-6">
        <div class="bg-surface-container-low rounded-xl p-5 lg:p-6 border border-white/5">
          <h3 class="text-lg font-bold tracking-tight text-on-surface mb-4">Modifier / supprimer clients</h3>
          <div class="space-y-3">
            <% if (!clientRows.length) { %>
              <p class="text-sm text-on-surface-variant">Aucun client a afficher.</p>
            <% } %>
            <% clientRows.forEach(client => { %>
              <div class="bg-surface-container rounded-lg p-4 space-y-3">
                <form action="/admin/update-client/<%= client.client_id %>" method="POST" class="grid grid-cols-1 md:grid-cols-2 gap-3">
                  <% if (scopedAdminSession) { %>
                    <input type="hidden" name="admin_employee_id" value="<%= scopedAdminSession.employee_id %>"/>
                    <input type="hidden" name="admin_hotel_id" value="<%= scopedAdminSession.hotel_id %>"/>
                  <% } %>
                  <input class="bg-surface-container-highest border-none rounded-lg p-3 text-on-surface" name="nom" value="<%= client.full_name %>" required type="text"/>
                  <input class="bg-surface-container-highest border-none rounded-lg p-3 text-on-surface" name="adresse" value="<%= client.address %>" required type="text"/>
                  <button class="signature-gradient text-on-primary font-bold py-2 px-4 rounded-lg" type="submit">Mettre a jour</button>
                </form>
                <form action="/admin/delete-client/<%= client.client_id %>" method="POST">
                  <% if (scopedAdminSession) { %>
                    <input type="hidden" name="admin_employee_id" value="<%= scopedAdminSession.employee_id %>"/>
                    <input type="hidden" name="admin_hotel_id" value="<%= scopedAdminSession.hotel_id %>"/>
                  <% } %>
                  <button class="text-red-300 text-xs font-bold uppercase tracking-widest" type="submit">Supprimer client #<%= client.client_id %></button>
                </form>
              </div>
            <% }) %>
          </div>
        </div>

        <div class="bg-surface-container-low rounded-xl p-5 lg:p-6 border border-white/5">
          <h3 class="text-lg font-bold tracking-tight text-on-surface mb-4">Modifier / supprimer employes</h3>
          <div class="space-y-3">
            <% if (!employeeRows.length) { %>
              <p class="text-sm text-on-surface-variant">Aucun employe a afficher.</p>
            <% } %>
            <% employeeRows.forEach(employee => { %>
              <div class="bg-surface-container rounded-lg p-4 space-y-3">
                <form action="/admin/update-employee/<%= employee.employee_id %>" method="POST" class="grid grid-cols-1 md:grid-cols-2 gap-3">
                  <% if (scopedAdminSession) { %>
                    <input type="hidden" name="admin_employee_id" value="<%= scopedAdminSession.employee_id %>"/>
                    <input type="hidden" name="admin_hotel_id" value="<%= scopedAdminSession.hotel_id %>"/>
                  <% } %>
                  <input class="bg-surface-container-highest border-none rounded-lg p-3 text-on-surface" name="nom" value="<%= employee.full_name %>" required type="text"/>
                  <select class="bg-surface-container-highest border-none rounded-lg p-3 text-on-surface" name="role">
                    <% ['Manager', 'Receptionist', 'Housekeeping', 'Admin', 'Other'].forEach(role => { %>
                      <option value="<%= role %>" <%= employee.role === role ? 'selected' : '' %>><%= role %></option>
                    <% }) %>
                  </select>
                  <button class="signature-gradient text-on-primary font-bold py-2 px-4 rounded-lg" type="submit">Mettre a jour</button>
                </form>
                <form action="/admin/delete-employee/<%= employee.employee_id %>" method="POST">
                  <% if (scopedAdminSession) { %>
                    <input type="hidden" name="admin_employee_id" value="<%= scopedAdminSession.employee_id %>"/>
                    <input type="hidden" name="admin_hotel_id" value="<%= scopedAdminSession.hotel_id %>"/>
                  <% } %>
                  <button class="text-red-300 text-xs font-bold uppercase tracking-widest" type="submit">Supprimer employe #<%= employee.employee_id %></button>
                </form>
              </div>
            <% }) %>
          </div>
        </div>

        <div class="bg-surface-container-low rounded-xl p-5 lg:p-6 border border-white/5">
          <h3 class="text-lg font-bold tracking-tight text-on-surface mb-4">Modifier hotels</h3>
          <div class="space-y-3 max-h-[520px] overflow-y-auto pr-1">
            <% hotels.slice(0, 10).forEach(hotel => { %>
              <div class="bg-surface-container rounded-lg p-4 space-y-3">
                <form action="/admin/update-hotel/<%= hotel.hotel_id %>" method="POST" class="grid grid-cols-1 md:grid-cols-2 gap-3">
                  <% if (scopedAdminSession) { %>
                    <input type="hidden" name="admin_employee_id" value="<%= scopedAdminSession.employee_id %>"/>
                    <input type="hidden" name="admin_hotel_id" value="<%= scopedAdminSession.hotel_id %>"/>
                  <% } %>
                  <input class="bg-surface-container-highest border-none rounded-lg p-3 text-on-surface" name="nom" value="<%= hotel.name %>" required type="text"/>
                  <input class="bg-surface-container-highest border-none rounded-lg p-3 text-on-surface" name="categorie" value="<%= hotel.category || 1 %>" min="1" max="5" required type="number"/>
                  <button class="signature-gradient text-on-primary font-bold py-2 px-4 rounded-lg" type="submit">Mettre a jour</button>
                </form>
              </div>
            <% }) %>
          </div>
        </div>

        <div class="bg-surface-container-low rounded-xl p-5 lg:p-6 border border-white/5">
          <h3 class="text-lg font-bold tracking-tight text-on-surface mb-4">Modifier / supprimer chambres</h3>
          <div class="space-y-3">
            <% if (!roomRows.length) { %>
              <p class="text-sm text-on-surface-variant">Aucune chambre a afficher.</p>
            <% } %>
            <% roomRows.forEach(room => { %>
              <div class="bg-surface-container rounded-lg p-4 space-y-3">
                <p class="text-xs text-on-surface-variant">#<%= room.room_id %> - <%= room.hotel_name %> - Chambre <%= room.room_number %></p>
                <form action="/admin/update-room/<%= room.room_id %>" method="POST" class="grid grid-cols-1 md:grid-cols-2 gap-3">
                  <% if (scopedAdminSession) { %>
                    <input type="hidden" name="admin_employee_id" value="<%= scopedAdminSession.employee_id %>"/>
                    <input type="hidden" name="admin_hotel_id" value="<%= scopedAdminSession.hotel_id %>"/>
                  <% } %>
                  <input class="bg-surface-container-highest border-none rounded-lg p-3 text-on-surface" name="prix" value="<%= room.price %>" min="0" step="0.01" required type="number"/>
                  <input class="bg-surface-container-highest border-none rounded-lg p-3 text-on-surface" name="damage_status" value="<%= room.damage_status || 'None' %>" type="text"/>
                  <button class="signature-gradient text-on-primary font-bold py-2 px-4 rounded-lg" type="submit">Mettre a jour</button>
                </form>
                <form action="/admin/delete-room/<%= room.room_id %>" method="POST">
                  <% if (scopedAdminSession) { %>
                    <input type="hidden" name="admin_employee_id" value="<%= scopedAdminSession.employee_id %>"/>
                    <input type="hidden" name="admin_hotel_id" value="<%= scopedAdminSession.hotel_id %>"/>
                  <% } %>
                  <button class="text-red-300 text-xs font-bold uppercase tracking-widest" type="submit">Supprimer chambre #<%= room.room_id %></button>
                </form>
              </div>
            <% }) %>
          </div>
        </div>
      </div>
    </section>
  </main>
</body>
</html>
