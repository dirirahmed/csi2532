<!DOCTYPE html>
<html lang="fr">

<head>
    <meta charset="UTF-8">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <title>e-Hôtels | Accueil</title>
    <style>
        body {
            background-color: #121416;
            color: #ffffff;
            font-family: 'Segoe UI', sans-serif;
        }
        
        .search-card {
            background: #212529;
            border: 1px solid #343a40;
            border-radius: 15px;
        }
        
        .form-control,
        .form-select {
            background-color: #2b3035 !important;
            color: #ffffff !important;
            border: 1px solid #495057;
        }
        
        .text-cyan {
            color: #0dcaf0;
        }
    </style>
</head>

<body>
    <nav class="navbar navbar-dark bg-black border-bottom border-secondary mb-5">
        <div class="container d-flex justify-content-between">
            <a class="navbar-brand fw-bold text-cyan" href="/">🏨 E-HÔTELS</a>
            <div>
                <a href="/employe" class="btn btn-outline-info btn-sm me-2">Employé</a>
                <a href="/admin" class="btn btn-outline-warning btn-sm">Admin</a>
            </div>
        </div>
    </nav>

    <div class="container">
        <div class="search-card p-5 shadow-lg">
            <h2 class="text-center mb-4">Critères de Recherche</h2>
            <form action="/rechercher" method="GET" class="row g-4">
                <div class="col-md-3">
                    <label class="form-label fw-bold">Arrivée</label>
                    <input type="date" name="dateDebut" class="form-control" required>
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-bold">Départ</label>
                    <input type="date" name="dateFin" class="form-control" required>
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-bold">Ville</label>
                    <select name="ville" class="form-select">
                        <option value="">Toutes les villes</option>
                        <option value="Ottawa">Ottawa</option>
                        <option value="Gatineau">Gatineau</option>
                        <option value="Montreal">Montreal</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-bold">Étoiles</label>
                    <select name="categorie" class="form-select">
                        <option value="">Toutes</option>
                        <option value="1">1 ★</option>
                        <option value="2">2 ★</option>
                        <option value="3" selected>3 ★</option>
                        <option value="4">4 ★</option>
                        <option value="5">5 ★</option>
                    </select>
                </div>

                <div class="col-md-4">
                    <label class="form-label fw-bold">Chaîne Hôtelière</label>
                    <select name="chaine" class="form-select">
                        <option value="">Toutes les chaînes</option>
                        <option value="Global Stay">Global Stay</option>
                        <option value="Maple Hotels">Maple Hotels</option>
                        <option value="Horizon">Horizon</option>
                        <option value="Nordic">Nordic</option>
                        <option value="Elite">Elite</option>
                    </select>
                </div>

                <div class="col-md-4">
                    <label class="form-label fw-bold">Type de Chambre</label>
                    <select name="capacite" class="form-select">
                        <option value="simple">Simple</option>
                        <option value="double" selected>Double</option>
                        <option value="suite">Suite</option>
                    </select>
                </div>

                <div class="col-md-4">
                    <label class="form-label fw-bold">Prix Max ($)</label>
                    <input type="number" name="prixMax" class="form-control" placeholder="999">
                </div>

                <div class="col-12 text-center mt-5">
                    <button type="submit" class="btn btn-info w-50 fw-bold">RECHERCHER DES DISPONIBILITÉS</button>
                </div>
            </form>
        </div>
    </div>
</body>

</html>