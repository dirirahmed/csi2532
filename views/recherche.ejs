<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <title>e-Hôtels | Accueil</title>
    <style>
        body { background-color: #1a1d20; color: #e9ecef; font-family: 'Segoe UI', sans-serif; }
        .search-card { background: #2c3034; border: none; border-radius: 15px; box-shadow: 0 8px 32px rgba(0,0,0,0.3); }
        .form-label { font-weight: 500; color: #adb5bd; }
        .btn-primary { background-color: #0d6efd; border: none; padding: 12px; transition: 0.3s; }
        .btn-primary:hover { background-color: #0b5ed7; transform: translateY(-2px); }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark border-bottom border-secondary">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/">🏨 e-Hôtels</a>
        </div>
    </nav>

    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-lg-10">
                <div class="search-card p-5">
                    <h2 class="mb-4 text-white">Trouvez votre séjour idéal</h2>
                    
                    <form action="/rechercher" method="GET" class="row g-4">
                        <div class="col-md-3">
                            <label class="form-label">Date d'arrivée</label>
                            <input type="date" name="dateDebut" class="form-control bg-dark text-white border-secondary" required>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Date de départ</label>
                            <input type="date" name="dateFin" class="form-control bg-dark text-white border-secondary" required>
                        </div>

                        <div class="col-md-3">
                            <label class="form-label">Type de chambre</label>
                            <select name="capacite" class="form-select bg-dark text-white border-secondary">
                                <option value="simple">Simple (Individuelle)</option>
                                <option value="double">Double (Grand lit)</option>
                                <option value="twin">Twin (2 Lits)</option>
                                <option value="suite">Suite</option>
                            </select>
                        </div>

                        <div class="col-md-3">
                            <label class="form-label">Catégorie</label>
                            <select name="categorie" class="form-select bg-dark text-white border-secondary">
                                <% for(let i=1; i<=5; i++) { %>
                                    <option value="<%= i %>" <%= i==3 ? 'selected' : '' %>><%= i %> Étoiles</option>
                                <% } %>
                            </select>
                        </div>

                        <div class="col-md-3">
                            <label class="form-label">Prix Min ($)</label>
                            <input type="number" name="prixMin" class="form-control bg-dark text-white border-secondary" placeholder="0">
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Prix Max ($)</label>
                            <input type="number" name="prixMax" class="form-control bg-dark text-white border-secondary" placeholder="999">
                        </div>

                        <div class="col-md-6 d-flex align-items-end">
                            <button type="submit" class="btn btn-primary w-100 fw-bold">RECHERCHER</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</body>
</html>