<!DOCTYPE html>
<html class="dark" lang="fr">
<head>
  <meta charset="utf-8"/>
  <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
  <title>e-Hotels Database - Recherche</title>
  <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet"/>
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
  <link href="/styles/ui.css" rel="stylesheet"/>
  <script>
    tailwind.config = {
      darkMode: "class",
      theme: {
        extend: {
          colors: {
            "tertiary-fixed": "#e2fbd9",
            "surface-container-lowest": "#000000",
            "primary-fixed-dim": "#50ebd5",
            "surface-variant": "#242625",
            "surface-dim": "#0e0e0e",
            "surface-container-high": "#1e201f",
            "secondary-fixed": "#e0e3e1",
            "tertiary": "#ecffe4",
            "tertiary-dim": "#d7efce",
            "on-tertiary-fixed-variant": "#566c52",
            "on-tertiary-container": "#475c43",
            "tertiary-fixed-dim": "#d4eccc",
            "on-tertiary-fixed": "#3a4f37",
            "error-container": "#7f2927",
            "primary-dim": "#22cfba",
            "on-surface-variant": "#aaabaa",
            "surface-container": "#181a19",
            "on-secondary-container": "#bdc0be",
            "background": "#0e0e0e",
            "on-secondary-fixed-variant": "#595c5b",
            "surface-tint": "#3cddc7",
            "primary-fixed": "#62fae3",
            "error": "#ee7d77",
            "on-primary-container": "#4ae7d1",
            "secondary-container": "#383c3b",
            "tertiary-container": "#daf2d1",
            "surface-bright": "#2a2d2c",
            "on-primary-fixed-variant": "#00675c",
            "on-surface": "#e5e6e4",
            "primary": "#3cddc7",
            "primary-container": "#005047",
            "on-primary": "#004941",
            "on-error-container": "#ff9993",
            "on-tertiary": "#4f654b",
            "inverse-primary": "#006b60",
            "secondary-dim": "#9b9e9d",
            "inverse-surface": "#fbf9f8",
            "surface-container-highest": "#242625",
            "secondary-fixed-dim": "#d2d5d3",
            "surface": "#0e0e0e",
            "error-dim": "#bb5551",
            "inverse-on-surface": "#555554",
            "surface-container-low": "#121413",
            "on-secondary": "#1d2120",
            "on-primary-fixed": "#004840",
            "outline": "#747675",
            "secondary": "#9b9e9d",
            "on-error": "#490106",
            "on-secondary-fixed": "#3c403f",
            "on-background": "#e5e6e4",
            "outline-variant": "#464847"
          }
        }
      }
    };
  </script>
  <style>
    body { font-family: 'Inter', sans-serif; background-color: #0e0e0e; color: #e5e6e4; }
    .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; }
    ::-webkit-scrollbar { width: 6px; }
    ::-webkit-scrollbar-track { background: #0e0e0e; }
    ::-webkit-scrollbar-thumb { background: #242625; border-radius: 10px; }
    ::-webkit-scrollbar-thumb:hover { background: #3cddc7; }
  </style>
</head>
<body class="antialiased overflow-x-hidden">
  <aside class="fixed left-0 top-0 h-screen flex flex-col py-6 px-4 gap-8 bg-[#0e0e0e] border-r border-white/5 w-64 z-50">
    <div class="flex items-center gap-3 px-2">
      <div class="w-8 h-8 rounded-lg signature-gradient flex items-center justify-center">
        <span class="material-symbols-outlined text-on-primary text-sm">inventory_2</span>
      </div>
      <div class="flex flex-col">
        <span class="text-teal-400 font-black tracking-tight leading-none">e-Hotels</span>
        <span class="text-[10px] text-on-surface-variant font-medium">CSI2532 Project</span>
      </div>
    </div>
    <nav class="flex flex-col gap-2 flex-grow">
      <a class="flex items-center gap-3 bg-teal-400/10 text-teal-400 rounded-lg px-4 py-2 border-l-4 border-teal-400 font-medium text-sm" href="/">
        <span class="material-symbols-outlined text-lg">dashboard</span>
        <span>Accueil</span>
      </a>
      <a class="flex items-center gap-3 text-[#aaabaa] px-4 py-2 hover:bg-[#181a19] rounded-lg transition-all font-medium text-sm" href="/employe">
        <span class="material-symbols-outlined text-lg">badge</span>
        <span>Employe</span>
      </a>
    </nav>
  </aside>
  <div class="ml-64 min-h-screen flex flex-col">
    <header class="sticky top-0 z-40 px-6 lg:px-8 py-4 bg-[#121413]/80 backdrop-blur-md border-b border-white/5">
      <form id="live-search-form" class="grid grid-cols-1 md:grid-cols-3 xl:grid-cols-5 2xl:grid-cols-9 gap-4 w-full">
        <div class="flex flex-col gap-1">
          <label class="text-[11px] text-on-surface-variant font-bold uppercase tracking-tighter" for="dateDebut">Arrival Date</label>
          <input class="bg-surface-container-highest border-none text-xs text-on-surface p-2 rounded focus:ring-1 focus:ring-primary" id="dateDebut" name="dateDebut" required type="date"/>
        </div>
        <div class="flex flex-col gap-1">
          <label class="text-[11px] text-on-surface-variant font-bold uppercase tracking-tighter" for="dateFin">Departure Date</label>
          <input class="bg-surface-container-highest border-none text-xs text-on-surface p-2 rounded focus:ring-1 focus:ring-primary" id="dateFin" name="dateFin" required type="date"/>
        </div>
        <div class="flex flex-col gap-1">
          <label class="text-[11px] text-on-surface-variant font-bold uppercase tracking-tighter" for="capacite">Capacity</label>
          <select class="bg-surface-container-highest border-none text-xs text-on-surface p-2 rounded focus:ring-1 focus:ring-primary" id="capacite" name="capacite">
            <option value="">Toutes</option>
            <option value="Single">Simple</option>
            <option value="Double">Double</option>
            <option value="Suite">Suite</option>
            <option value="Family">Family</option>
          </select>
        </div>
        <div class="flex flex-col gap-1">
          <label class="text-[11px] text-on-surface-variant font-bold uppercase tracking-tighter" for="superficie">Surface (m²)</label>
          <input class="bg-surface-container-highest border-none text-xs text-on-surface p-2 rounded focus:ring-1 focus:ring-primary" id="superficie" min="0" name="superficie" type="number"/>
        </div>
        <div class="flex flex-col gap-1">
          <label class="text-[11px] text-on-surface-variant font-bold uppercase tracking-tighter" for="chaine">Hotel Chain</label>
          <select class="bg-surface-container-highest border-none text-xs text-on-surface p-2 rounded focus:ring-1 focus:ring-primary" id="chaine" name="chaine">
            <option value="">Toutes</option>
            <% chains.forEach(chain => { %>
              <option value="<%= chain.name %>"><%= chain.name %></option>
            <% }) %>
          </select>
        </div>
        <div class="flex flex-col gap-1">
          <label class="text-[11px] text-on-surface-variant font-bold uppercase tracking-tighter" for="categorie">Category</label>
          <select class="bg-surface-container-highest border-none text-xs text-on-surface p-2 rounded focus:ring-1 focus:ring-primary" id="categorie" name="categorie">
            <option value="">Toutes</option>
            <option value="1">1 Star</option>
            <option value="2">2 Stars</option>
            <option value="3">3 Stars</option>
            <option value="4">4 Stars</option>
            <option value="5">5 Stars</option>
          </select>
        </div>
        <div class="flex flex-col gap-1">
          <label class="text-[11px] text-on-surface-variant font-bold uppercase tracking-tighter" for="ville">Ville</label>
          <select class="bg-surface-container-highest border-none text-xs text-on-surface p-2 rounded focus:ring-1 focus:ring-primary" id="ville" name="ville">
            <option value="">Toutes</option>
            <% cities.forEach(city => { %>
              <option value="<%= city %>"><%= city %></option>
            <% }) %>
          </select>
        </div>
        <div class="flex flex-col gap-1">
          <label class="text-[11px] text-on-surface-variant font-bold uppercase tracking-tighter" for="numChambres">Rooms</label>
          <input class="bg-surface-container-highest border-none text-xs text-on-surface p-2 rounded focus:ring-1 focus:ring-primary" id="numChambres" min="0" name="numChambres" type="number"/>
        </div>
        <div class="flex flex-col gap-1">
          <label class="text-[11px] text-on-surface-variant font-bold uppercase tracking-tighter" for="prixMax">Prix Max</label>
          <input class="bg-surface-container-highest border-none text-xs text-on-surface p-2 rounded focus:ring-1 focus:ring-primary" id="prixMax" min="0" name="prixMax" type="number"/>
        </div>
        <div class="flex flex-col justify-end">
          <button class="bg-gradient-to-r from-primary to-primary-container text-on-primary px-4 py-2 rounded font-bold text-xs flex items-center justify-center gap-2 hover:opacity-90 transition-opacity h-[38px]" type="submit">
          <span class="material-symbols-outlined text-sm">filter_alt</span>
          RUN QUERY
        </button>
        </div>
      </form>
    </header>

    <main class="p-6 lg:p-8 flex-grow bg-surface">
      <div class="flex items-center justify-between mb-8">
        <div>
          <h2 class="text-2xl font-bold tracking-tight text-on-surface">Available Inventory</h2>
          <div class="flex items-center gap-2 mt-1">
            <span class="w-2 h-2 rounded-full bg-primary animate-pulse"></span>
            <p class="text-xs text-on-surface-variant font-medium" id="results-subtitle">Choisissez des dates pour lancer la recherche en direct.</p>
          </div>
        </div>
      </div>

      <div id="results-state" class="hidden mb-6 rounded-lg border border-white/5 bg-surface-container-low p-4 text-sm text-on-surface-variant"></div>
      <div id="results-grid" class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6"></div>
    </main>
  </div>

  <template id="room-card-template">
    <div class="bg-surface-container rounded-lg overflow-hidden group border border-transparent hover:border-primary/20 transition-all duration-300">
      <div class="p-6">
        <div class="flex justify-between items-start mb-4 gap-4">
          <div>
            <div class="text-[10px] font-bold uppercase tracking-widest text-primary mb-2 room-chain"></div>
            <h3 class="font-bold text-lg text-on-surface tracking-tight room-name"></h3>
            <div class="text-xs text-on-surface-variant mt-1 room-category"></div>
          </div>
          <div class="text-right">
            <span class="text-xl font-black text-on-surface room-price"></span>
            <p class="text-[10px] text-on-surface-variant uppercase font-bold">Per Night</p>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-y-4 gap-x-2 mb-6">
          <div class="flex items-center gap-2">
            <span class="material-symbols-outlined text-sm text-primary-fixed-dim">groups</span>
            <span class="text-xs text-on-surface-variant room-capacity"></span>
          </div>
          <div class="flex items-center gap-2">
            <span class="material-symbols-outlined text-sm text-primary-fixed-dim">square_foot</span>
            <span class="text-xs text-on-surface-variant room-area"></span>
          </div>
          <div class="flex items-center gap-2">
            <span class="material-symbols-outlined text-sm text-primary-fixed-dim">visibility</span>
            <span class="text-xs text-on-surface-variant room-view"></span>
          </div>
          <div class="flex items-center gap-2">
            <span class="material-symbols-outlined text-sm text-primary-fixed-dim">hotel</span>
            <span class="text-xs text-on-surface-variant room-city"></span>
          </div>
          <div class="col-span-2 flex items-center gap-2">
            <span class="material-symbols-outlined text-sm text-primary-fixed-dim">checklist</span>
            <span class="text-xs text-on-surface-variant room-amenities"></span>
          </div>
        </div>
        <form action="/reserver" method="POST" class="reserve-form">
          <input name="id" type="hidden" class="room-id"/>
          <input name="dateDebut" type="hidden" class="room-date-debut"/>
          <input name="dateFin" type="hidden" class="room-date-fin"/>
          <button class="w-full bg-surface-container-highest border border-outline-variant/20 hover:border-primary/50 text-primary py-3 rounded font-bold text-xs uppercase tracking-widest transition-all" type="submit">
            Reserve Entry
          </button>
        </form>
      </div>
    </div>
  </template>

  <script>
    const form = document.getElementById('live-search-form');
    const resultsGrid = document.getElementById('results-grid');
    const resultsSubtitle = document.getElementById('results-subtitle');
    const resultsState = document.getElementById('results-state');
    const template = document.getElementById('room-card-template');
    let debounceTimer;

    function setDefaultDates() {
      const today = new Date();
      const tomorrow = new Date(today);
      tomorrow.setDate(today.getDate() + 1);
      const toInput = (date) => date.toISOString().split('T')[0];
      document.getElementById('dateDebut').value = toInput(today);
      document.getElementById('dateFin').value = toInput(tomorrow);
    }

    function updateState(message, show) {
      resultsState.textContent = message;
      resultsState.classList.toggle('hidden', !show);
    }

    function renderRooms(chambres) {
      resultsGrid.innerHTML = '';

      if (!chambres.length) {
        updateState('Aucune chambre ne correspond a ces criteres.', true);
        return;
      }

      updateState('', false);
      const dateDebut = document.getElementById('dateDebut').value;
      const dateFin = document.getElementById('dateFin').value;

      chambres.forEach((chambre) => {
        const node = template.content.firstElementChild.cloneNode(true);
        node.querySelector('.room-chain').textContent = chambre.chaine;
        node.querySelector('.room-name').textContent = chambre.nom_hotel;
        const bedMap = { Single: '1 lit', Double: '2 lits', Suite: '3 lits', Family: '4 lits' };
        const bedLabel = bedMap[chambre.capacite] || chambre.capacite;
        const litAdditionnel = Number(chambre.lit_additionnel) ? 'Lit additionnel: Oui' : 'Lit additionnel: Non';
        node.querySelector('.room-category').textContent = `${chambre.categorie} etoiles • ${bedLabel}`;
        node.querySelector('.room-price').textContent = `${chambre.prix}$`;
        node.querySelector('.room-capacity').textContent = `Capacite: ${chambre.capacite}`;
        node.querySelector('.room-area').textContent = `Surface: ${chambre.superficie} m²`;
        node.querySelector('.room-view').textContent = `Vue: ${chambre.vue || 'None'}`;
        node.querySelector('.room-city').textContent = `${litAdditionnel} • ${chambre.ville}`;
        node.querySelector('.room-amenities').textContent = `${chambre.commodites || 'Aucune commodite specifiee'} • Etat: ${chambre.etat || 'None'}`;
        node.querySelector('.room-id').value = chambre.id_chambre;
        node.querySelector('.room-date-debut').value = dateDebut;
        node.querySelector('.room-date-fin').value = dateFin;
        resultsGrid.appendChild(node);
      });
    }

    async function runSearch() {
      const params = new URLSearchParams(new FormData(form));
      const dateDebut = params.get('dateDebut');
      const dateFin = params.get('dateFin');

      if (!dateDebut || !dateFin) {
        resultsSubtitle.textContent = 'Choisissez des dates pour lancer la recherche en direct.';
        resultsGrid.innerHTML = '';
        updateState('', false);
        return;
      }

      resultsSubtitle.textContent = 'Chargement en direct...';

      try {
        const response = await fetch(`/api/rechercher?${params.toString()}`);
        const data = await response.json();

        if (!response.ok) {
          throw new Error(data.error || 'Search Error');
        }

        resultsSubtitle.textContent = `${data.chambres.length} chambre(s) disponible(s) pour la periode selectionnee.`;
        renderRooms(data.chambres);
      } catch (error) {
        resultsGrid.innerHTML = '';
        resultsSubtitle.textContent = 'La recherche en direct a echoue.';
        updateState(error.message || 'Search Error', true);
      }
    }

    setDefaultDates();
    form.addEventListener('submit', (event) => {
      event.preventDefault();
      runSearch();
    });

    form.querySelectorAll('input, select').forEach((field) => {
      field.addEventListener('input', () => {
        clearTimeout(debounceTimer);
        debounceTimer = setTimeout(runSearch, 250);
      });
      field.addEventListener('change', runSearch);
    });

    runSearch();
  </script>
</body>
</html>
