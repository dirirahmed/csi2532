<!DOCTYPE html>
<html lang="fr">
<head>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <title>Résultats | e-Hôtels</title>
    <style>
        body { background-color: #1a1d20; color: #e9ecef; }
        .room-card { background: #2c3034; border-radius: 12px; transition: 0.3s; }
        .room-card:hover { transform: scale(1.02); background: #343a40; }
        .price-tag { color: #0d6efd; font-size: 1.5rem; font-weight: bold; }
    </style>
</head>
<body class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-5">
        <h2>Chambres Disponibles</h2>
        <a href="/" class="btn btn-outline-light">Nouvelle Recherche</a>
    </div>

    <div class="row g-4">
        <% chambres.forEach(chambre => { %>
            <div class="col-md-6 col-lg-4">
                <div class="room-card p-4 shadow">
                    <h5 class="text-white"><%= chambre.nom_hotel %></h5>
                    <p class="text-muted"><%= chambre.categorie %> ★ Stars</p>
                    <hr class="border-secondary">
                    <p><strong>Type:</strong> <%= chambre.capacite %></p>
                    <p><strong>Vue:</strong> <%= chambre.vue || 'Standard' %></p> <p class="small">✨ <%= chambre.commodites %></p>
                    <div class="d-flex justify-content-between align-items-center mt-3">
                        <span class="price-tag"><%= chambre.prix %>$</span>
                        <form action="/reserver" method="POST">
                            <input type="hidden" name="chId" value="<%= chambre.id_chambre %>">
                            <button class="btn btn-success">Réserver</button>
                        </form>
                    </div>
                </div>
            </div>
        <% }) %>
    </div>
</body>
</html>