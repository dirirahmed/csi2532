<!DOCTYPE html>
<html lang="fr">
<head>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { background-color: #121416; color: #ffffff; }
        .room-card { background: #212529; border: 1px solid #343a40; border-radius: 12px; }
        .text-cyan { color: #0dcaf0; }
    </style>
</head>
<body class="container py-5">
    <div class="d-flex justify-content-between mb-4">
        <h2 class="text-white">Chambres Disponibles</h2>
        <a href="/" class="btn btn-outline-light">Retour</a>
    </div>

    <div class="row g-4">
        <% chambres.forEach(ch => { %>
            <div class="col-md-6 col-lg-4">
                <div class="room-card p-4">
                    <h5 class="text-cyan fw-bold"><%= ch.nom_hotel %></h5>
                    <p class="small text-white-50"><%= ch.categorie %> ★ Stars</p>
                    <hr class="border-secondary">
                    <p class="mb-1 text-white"><strong>Type:</strong> <%= ch.capacite %></p>
                    <p class="mb-1 text-white"><strong>Vue:</strong> <%= ch.vue %></p>
                    <p class="mb-1 text-white"><strong>Surface:</strong> <%= ch.superficie %> m²</p>
                    <p class="small text-info">✨ <%= ch.commodites %></p>
                    <div class="d-flex justify-content-between align-items-center mt-3">
                        <span class="h4 text-white mb-0 fw-bold"><%= ch.prix %>$</span>
                        <form action="/reserver" method="POST">
                            <input type="hidden" name="id" value="<%= ch.id_chambre %>">
                            <button class="btn btn-success fw-bold">Réserver</button>
                        </form>
                    </div>
                </div>
            </div>
        <% }) %>
    </div>
</body>
</html>