<!DOCTYPE html>
<html class="dark" lang="fr">
<head>
  <meta charset="utf-8"/>
  <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
  <title>e-Hotels Database - Stats</title>
  <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet"/>
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
  <link href="/styles/ui.css" rel="stylesheet"/>
  <script>
    tailwind.config = {
      darkMode: 'class',
      theme: {
        extend: {
          colors: {
            background: '#0e0e0e',
            surface: '#0e0e0e',
            'surface-container-low': '#121413',
            'surface-container': '#181a19',
            'surface-container-high': '#1e201f',
            primary: '#3cddc7',
            'primary-container': '#005047',
            'on-primary': '#004941',
            'on-surface': '#e5e6e4',
            'on-surface-variant': '#aaabaa',
            'outline-variant': '#464847'
          }
        }
      }
    };
  </script>
</head>
<body class="bg-background text-on-surface min-h-screen flex">
  <aside class="hidden md:flex sticky top-0 flex-col h-screen py-6 px-4 gap-8 bg-[#0e0e0e] border-r border-white/5 w-64 shrink-0 self-start">
    <div class="flex items-center gap-3 px-2">
      <div class="w-8 h-8 rounded-lg signature-gradient flex items-center justify-center">
        <span class="material-symbols-outlined text-on-primary text-sm">inventory_2</span>
      </div>
      <div class="flex flex-col">
        <span class="text-teal-400 font-black tracking-tight leading-none">e-Hotels</span>
        <span class="text-[10px] text-on-surface-variant font-medium">CSI2532 Project</span>
      </div>
    </div>
    <nav class="flex flex-col gap-2 flex-grow">
      <a class="flex items-center gap-3 text-[#aaabaa] px-4 py-2 hover:bg-[#181a19] rounded-lg transition-all font-medium text-sm" href="/">
        <span class="material-symbols-outlined text-lg">dashboard</span>
        <span>Accueil</span>
      </a>
      <a class="flex items-center gap-3 text-[#aaabaa] px-4 py-2 hover:bg-[#181a19] rounded-lg transition-all font-medium text-sm" href="/employe">
        <span class="material-symbols-outlined text-lg">badge</span>
        <span>Employe</span>
      </a>
      <a class="flex items-center gap-3 text-[#aaabaa] px-4 py-2 hover:bg-[#181a19] rounded-lg transition-all font-medium text-sm" href="/admin">
        <span class="material-symbols-outlined text-lg">admin_panel_settings</span>
        <span>Admin</span>
      </a>
      <a class="flex items-center gap-3 bg-teal-400/10 text-teal-400 rounded-lg px-4 py-2 border-l-4 border-teal-400 font-medium text-sm" href="/stats">
        <span class="material-symbols-outlined text-lg">analytics</span>
        <span>Stats</span>
      </a>
    </nav>
  </aside>

  <div class="flex-1 flex flex-col min-w-0 overflow-y-auto">
    <header class="bg-[#121413]/80 backdrop-blur-lg flex items-center w-full px-8 h-16 sticky top-0 z-50 border-b border-white/5">
      <div class="flex flex-col">
        <span class="text-teal-400 font-bold tracking-tighter uppercase text-sm">e-Hotels</span>
        <span class="text-[10px] text-on-surface-variant uppercase tracking-widest font-bold">Statistics Dashboard</span>
      </div>
    </header>

    <main class="p-6 lg:p-8 max-w-6xl w-full mx-auto space-y-8">
      <div>
        <a class="inline-flex items-center gap-2 text-primary hover:text-white transition-colors mb-4 text-sm font-medium" href="/admin">
          <span class="material-symbols-outlined text-sm">arrow_back</span>
          Retour Admin
        </a>
        <h2 class="text-2xl lg:text-3xl font-extrabold text-on-surface tracking-tight">Statistiques du reseau</h2>
        <p class="text-on-surface-variant mt-1">Disponibilite par ville et capacite totale par hotel.</p>
      </div>

      <section class="space-y-4">
        <div class="flex items-center gap-3">
          <div class="h-8 w-1.5 bg-primary rounded-full"></div>
          <h3 class="text-sm font-bold uppercase tracking-[0.08em] text-on-surface">Chambres disponibles par ville</h3>
        </div>
        <div class="overflow-hidden bg-surface-container-low rounded-xl border border-outline-variant/10">
          <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
              <thead>
                <tr class="bg-surface-container-high">
                  <th class="px-6 py-4 text-xs font-bold uppercase tracking-widest text-teal-400">Ville</th>
                  <th class="px-6 py-4 text-xs font-bold uppercase tracking-widest text-teal-400 text-right">Chambres libres</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-outline-variant/10">
                <% if (!cityStats.length) { %>
                  <tr>
                    <td class="px-6 py-5 text-on-surface-variant" colspan="2">Aucune statistique disponible.</td>
                  </tr>
                <% } %>
                <% cityStats.forEach(stat => { %>
                  <tr class="hover:bg-surface-container transition-colors">
                    <td class="px-6 py-5 text-on-surface font-semibold"><%= stat.city || stat.zone %></td>
                    <td class="px-6 py-5 text-right font-mono text-primary"><%= stat.available_room_count %></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      </section>

      <section class="space-y-4">
        <div class="flex items-center gap-3">
          <div class="h-8 w-1.5 bg-primary rounded-full"></div>
          <h3 class="text-sm font-bold uppercase tracking-[0.08em] text-on-surface">Capacite totale des chambres d'un hotel</h3>
        </div>
        <div class="overflow-hidden bg-surface-container-low rounded-xl border border-outline-variant/10">
          <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
              <thead>
                <tr class="bg-surface-container-high">
                  <th class="px-6 py-4 text-xs font-bold uppercase tracking-widest text-teal-400">Hotel</th>
                  <th class="px-6 py-4 text-xs font-bold uppercase tracking-widest text-teal-400 text-right">Capacite totale</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-outline-variant/10">
                <% if (!hotelStats.length) { %>
                  <tr>
                    <td class="px-6 py-5 text-on-surface-variant" colspan="2">Aucune statistique disponible.</td>
                  </tr>
                <% } %>
                <% hotelStats.forEach(h => { %>
                  <tr class="hover:bg-surface-container transition-colors">
                    <td class="px-6 py-5 text-on-surface font-semibold"><%= h.hotel_name %></td>
                    <td class="px-6 py-5 text-right font-mono text-on-surface"><%= h.total_capacity %></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      </section>
    </main>
  </div>
</body>
</html>
