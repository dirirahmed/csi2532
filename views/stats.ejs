<!DOCTYPE html>
<html lang="fr">
<head>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>body { background:#121416; color:white; }</style>
    <title>Stats</title>
</head>
<body class="container py-5">
    <h2 class="mb-5" style="color:#0dcaf0;">📊 Vues SQL (Stats)</h2>
    <div class="row g-4 text-center">
        <div class="col-md-6">
            <div class="p-4 bg-dark border border-secondary rounded shadow">
                <h6>Disponibilité par Zone</h6>
                <h3 class="text-info"><%= views.dispo %> chambres</h3>
                <p class="small text-muted"><%= views.zone %></p>
            </div>
        </div>
        <div class="col-md-6">
            <div class="p-4 bg-dark border border-secondary rounded shadow">
                <h6>Capacité par Hôtel</h6>
                <h3 class="text-info"><%= views.capacite %> places</h3>
                <p class="small text-muted"><%= views.hotel %></p>
            </div>
        </div>
    </div>
    <a href="/admin" class="btn btn-secondary mt-5">Retour Admin</a>
</body>
</html>