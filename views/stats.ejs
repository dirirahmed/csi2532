<!DOCTYPE html>
<html lang="fr">

<head>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body {
            background: #121416;
            color: white;
        }
        
        .card {
            background: #212529;
            border: 1px solid #495057;
        }
        
        .table {
            color: white;
        }
    </style>
    <title>Statistiques d'Hôtel</title>
</head>

<body class="container py-5">
    <div class="d-flex justify-content-between mb-5">
        <h2 style="color: #0dcaf0;">📊 Statistiques du Réseau</h2>
        <a href="/admin" class="btn btn-outline-light">Retour Admin</a>
    </div>

    <div class="row">
        <div class="col-md-6">
            <div class="card p-4">
                <h4 class="mb-4">Disponibilité par Ville</h4>
                <table class="table table-dark">
                    <thead>
                        <tr>
                            <th>Ville</th>
                            <th>Chambres Libres</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% cityStats.forEach(stat => { %>
                            <tr>
                                <td>
                                    <%= stat.city %>
                                </td>
                                <td>
                                    <%= stat.available_room_count %>
                                </td>
                            </tr>
                            <% }) %>
                    </tbody>
                </table>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card p-4">
                <h4 class="mb-4">Capacité Totale par Hôtel</h4>
                <table class="table table-dark">
                    <thead>
                        <tr>
                            <th>Hôtel</th>
                            <th>Capacité Totale</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% hotelStats.forEach(h => { %>
                            <tr>
                                <td>
                                    <%= h.hotel_name %>
                                </td>
                                <td>
                                    <%= h.total_capacity %>
                                </td>
                            </tr>
                            <% }) %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</body>

</html>